<Window
    x:Class="DesktopOrganizer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:DesktopOrganizer.App.ViewModels"
    xmlns:views="clr-namespace:DesktopOrganizer.App.Views"
    Title="Desktop Organizer"
    Width="1280"
    Height="720"
    Background="#E5E7EB"
    mc:Ignorable="d">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:FenceGroupViewModel}">
            <views:FenceGroupView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border
            Padding="16,12"
            Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button
                    Padding="12,6"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding CreateGroupCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" />
                        <TextBlock Text="New Group" FontSize="14" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button
                    Margin="12,0,0,0"
                    Padding="12,6"
                    Background="#F3F4F6"
                    Foreground="#374151"
                    BorderThickness="0"
                    Command="{Binding SaveCommand}">
                    <TextBlock Text="Save" FontSize="14" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Group surface -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="24" ItemsSource="{Binding Groups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="0,0,16,16" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
