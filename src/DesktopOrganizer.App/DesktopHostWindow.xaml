<Window
    x:Class="DesktopOrganizer.App.DesktopHostWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:DesktopOrganizer.App.ViewModels"
    xmlns:views="clr-namespace:DesktopOrganizer.App.Views"
    Title="Desktop Organizer Host"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="False"
    mc:Ignorable="d">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:BasketViewModel}">
            <views:BasketView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Minimal floating toolbar -->
        <Border
            Grid.Row="0"
            Margin="16,8,16,0"
            Padding="14,8"
            HorizontalAlignment="Center"
            Background="#CCF0ECE2"
            BorderBrush="#88A88E5E"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Desktop Organizer" />
                <TextBlock
                    Margin="12,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="#886B5A3C"
                    Text="{Binding StatusText}" />
                <Button
                    Margin="0,0,6,0"
                    Padding="10,5"
                    Background="#CCD5C4A1"
                    BorderThickness="0"
                    Command="{Binding RefreshDesktopCommand}"
                    Content="Refresh" />
                <Button
                    Padding="10,5"
                    Background="#CCA88E5E"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding OpenSettingsCommand}"
                    Content="Settings" />
            </StackPanel>
        </Border>

        <!-- Free-form canvas for draggable baskets -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding AllBaskets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>
    </Grid>
</Window>
