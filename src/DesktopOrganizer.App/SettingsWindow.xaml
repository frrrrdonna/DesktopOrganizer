<Window
    x:Class="DesktopOrganizer.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Desktop Organizer Settings"
    Width="520"
    Height="420"
    Background="#F7F3E8"
    WindowStartupLocation="CenterScreen">
    <Border Padding="20">
        <StackPanel>
            <TextBlock
                Margin="0,0,0,16"
                FontSize="24"
                FontWeight="Bold"
                Text="{Binding Loc.Title}" />

            <CheckBox
                Margin="0,0,0,10"
                Content="{Binding Loc.ReplaceDesktopOnStartup}"
                IsChecked="{Binding ReplaceDesktopOnStartup}" />

            <CheckBox
                Margin="0,0,0,10"
                Content="{Binding Loc.HideDesktopIcons}"
                IsChecked="{Binding HideDesktopIcons}" />

            <CheckBox
                Margin="0,0,0,10"
                Content="{Binding Loc.AutoGenerateBaskets}"
                IsChecked="{Binding AutoGenerateBaskets}" />

            <CheckBox
                Margin="0,0,0,10"
                Content="{Binding Loc.RestoreDesktopOnExit}"
                IsChecked="{Binding RestoreDesktopOnExit}" />

            <!-- Language selector -->
            <StackPanel
                Margin="0,8,0,10"
                Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    Text="{Binding Loc.Language}" />
                <ComboBox
                    Width="120"
                    ItemsSource="{Binding SupportedLanguages}"
                    SelectedItem="{Binding SelectedLanguage}" />
            </StackPanel>

            <CheckBox
                Margin="0,0,0,18"
                Content="{Binding Loc.PhysicallyOrganize}"
                IsEnabled="False"
                IsChecked="False" />

            <TextBlock
                Margin="0,0,0,18"
                Foreground="#6B5A3C"
                Text="{Binding Loc.Footer}"
                TextWrapping="Wrap" />

            <Button
                Width="96"
                Padding="10,6"
                HorizontalAlignment="Right"
                Background="#A88E5E"
                Foreground="White"
                BorderThickness="0"
                Content="{Binding Loc.Close}"
                Click="OnCloseClicked" />
        </StackPanel>
    </Border>
</Window>
