<UserControl
    x:Class="DesktopOrganizer.App.Views.BasketView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:viewModels="clr-namespace:DesktopOrganizer.App.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:BasketViewModel}"
    mc:Ignorable="d">
    <Border
        Width="{Binding PanelWidth}"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="20"
                Opacity="0.25"
                ShadowDepth="2"
                Color="#40000000" />
        </Border.Effect>
        <Border.Background>
            <SolidColorBrush Color="#CCF7F3E8" />
        </Border.Background>
        <Border
            Padding="12"
            Background="Transparent"
            BorderBrush="#88DDD1BB"
            BorderThickness="1"
            CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Draggable title bar -->
                <primitives:Thumb
                    DragDelta="OnDragDelta"
                    DragCompleted="OnDragCompleted"
                    Cursor="SizeAll">
                    <primitives:Thumb.Template>
                        <ControlTemplate TargetType="primitives:Thumb">
                            <Border
                                Padding="0,0,0,10"
                                Background="Transparent"
                                BorderBrush="#60A88E5E"
                                BorderThickness="0,0,0,1">
                                <DockPanel LastChildFill="False">
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="#CC1A1814"
                                        Text="{Binding Name}" />
                                    <Button
                                        DockPanel.Dock="Right"
                                        Padding="6,3"
                                        Background="#44D5C4A1"
                                        BorderThickness="0"
                                        Command="{Binding ToggleCollapseCommand}"
                                        Cursor="Hand">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#CC1A1814"
                                            Text="▼" />
                                    </Button>
                                </DockPanel>
                            </Border>
                        </ControlTemplate>
                    </primitives:Thumb.Template>
                </primitives:Thumb>

                <!-- Scrollable items -->
                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="8"
                                    Background="#DDFFFDF8"
                                    CornerRadius="10">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock
                                            Width="190"
                                            VerticalAlignment="Center"
                                            Foreground="#CC1A1814"
                                            Text="{Binding DisplayName}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Button
                                            DockPanel.Dock="Right"
                                            Padding="6,3"
                                            Background="#44D5C4A1"
                                            BorderThickness="0"
                                            Command="{Binding OpenCommand}">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="#CC1A1814"
                                                Text="▶" />
                                        </Button>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</UserControl>
